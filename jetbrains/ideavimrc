" Disable bloody bell
set visualbell

" Enable which-key extension
set which-key

" Disable which-key timeout, i.e. show the menu until you press a key
set notimeout

" increase the timeoutlen (default: 1000)
set timeoutlen = 500

" make the popup appear much slower
let g:WhichKey_DefaultDelay = 100

" Can not be remapped, but can be rebuilt with proper keybindings
" https://youtrack.jetbrains.com/issue/VIM-2372/Remap-NERDTree-default-keys
set NERDTree

set commentary

" set sneak
set quickscope

set surround
set textobj-indent

let mapleader = " "

set hlsearch
set incsearch
set ignorecase
set smartcase
set showmode
" set easymotion
" set nonumber
set number
set relativenumber
set scrolloff=3
set history=100000

map <C-o> <Action>(Back)
map <C-i> <Action>(Forward)

map <leader>d "_d
" easy access to the black hole register
nnoremap Q  "_
" use ; for registers in Visual mode
vnoremap ; "

" Go to tab by number
noremap <leader>1 1gt
noremap <leader>2 2gt
noremap <leader>3 3gt
noremap <leader>4 4gt
noremap <leader>5 5gt
noremap <leader>6 6gt
noremap <leader>7 7gt
noremap <leader>8 8gt
noremap <leader>9 9gt
